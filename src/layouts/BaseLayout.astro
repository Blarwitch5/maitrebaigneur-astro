---
import Favicon from "@components/head/Favicon.astro";
import GeoTag from "@components/head/GeoTag.astro";
import JsonLd from "@components/head/JsonLd.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "SportsActivityLocation"],
  "name": "Maître Baigneur",
  "description": "Cours de natation pour tous les âges à Aix-en-Provence et ses environs. Bébés nageurs dès 3 mois, enfants, adultes débutants ou confirmés. Maîtres nageurs qualifiés.",
  "url": "https://maitrebaigneur.com",
  "logo": {
    "@type": "ImageObject",
    "url": "https://maitrebaigneur.com/images/logo.svg"
  },
  "image": "https://maitrebaigneur.com/images/og/og-default.jpg",
  "telephone": "+33677007584",
  "email": "contact@maitrebaigneur.com",
  "identifier": {
    "@type": "PropertyValue",
    "name": "SIRET",
    "value": "93956033000010"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Aix-en-Provence",
    "addressRegion": "Provence-Alpes-Côte d'Azur",
    "postalCode": "13100",
    "addressCountry": "FR"
  },
  "areaServed": [
    { "@type": "City", "name": "Aix-en-Provence" },
    { "@type": "City", "name": "Saint-Marc-Jaumegarde" },
    { "@type": "City", "name": "Pertuis" },
    { "@type": "City", "name": "Saint-Maximin-la-Sainte-Baume" }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "174",
    "bestRating": "5",
    "worstRating": "1"
  },
  "sameAs": [
    "https://www.facebook.com/MaitreBaigneur/",
    "https://www.instagram.com/maitre_baigneur_aix/"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Prestations",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Cours de natation",
          "url": "https://maitrebaigneur.com/prestations/cours-de-natation"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Cours bébé nageur",
          "url": "https://maitrebaigneur.com/prestations/cours-bebe-nageur"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Aquaversaire",
          "url": "https://maitrebaigneur.com/prestations/aquaversaire"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Événements & Sécurité",
          "url": "https://maitrebaigneur.com/prestations/evenement-securite"
        }
      }
    ]
  }
};

import "aos/dist/aos.css";

import { SEO } from "astro-seo";
import { ClientRouter } from 'astro:transitions';
export interface SeoProps {
  title: string;
  description: string;
  openGraphType?: string;
  openGraphTitle?: string;
  openGraphDescription?: string;
  openGraphImage?: string;
  openGraphImageAlt?: string;
}
const canonical: URL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description,
  openGraphType,
  openGraphTitle,
  openGraphDescription,
  openGraphImage,
  openGraphImageAlt,
} = Astro.props;

const siteTitle: string = "Maître Baigneur";

import "sanitize.css";
import "../assets/styles/main.scss";

//differents geotag for the different pools, default is aix-en-provence (10KM acurancy)
const region: string = "FR-13";
const placename: string = "Aix-en-Provence";
const position: string = "43.5;5.4";
const icbm: string = "43.5, 5.4";
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={`${title} | ${siteTitle}`}
      description={description}
      canonical={canonical.toString()}
      openGraph={{
        basic: {
          type: openGraphType ? openGraphType : "website",
          title: openGraphTitle ? openGraphTitle : title,
          image: openGraphImage ? openGraphImage : "/images/og/og-default.jpg",
          url: canonical.toString(),
        },
        image: {
          alt: openGraphImageAlt
            ? openGraphImageAlt
            : "Découvrez les cours de natation pour tous les âges chez Maître Baigneur - de la piscine pour les bébés nageurs dès 3 mois aux leçons de natation pour enfants et adultes débutants ou confirmés.",
        },
        optional: {
          description: openGraphDescription
            ? openGraphDescription
            : "Cours de natation pour tous les âges chez Maître Baigneur - bébés nageurs dès 3 mois, enfants, adultes débutants ou confirmés. Maîtres nageurs qualifiés pour une expérience de natation optimale.",
        },
      }}
      extend={{
        // extending the default meta tags
        meta: [
          {
            name: "twitter:image",
            content: "/images/og/og-default.jpg",
          },
          { name: "twitter:title", content: "Maître-Baigneur" },
          {
            name: "twitter:description",
            content:
              "Cours de natation pour tous les âges chez Maître Baigneur - bébés nageurs dès 3 mois, enfants, adultes débutants ou confirmés. Maîtres nageurs qualifiés pour une expérience de natation optimale.",
          },
        ],
      }}
    />
    <!-- SITEMAP -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- GEOTAG -->
    <GeoTag
      region={region}
      placename={placename}
      position={position}
      icbm={icbm}
    />
    <!-- /GEOTAG -->

    <!-- FAVICON -->
    <Favicon />
    <!-- /FAVICON -->
    <JsonLd schema={localBusinessSchema} />
    <ClientRouter />
  </head>
  <body>
    <slot />

    <script src="../assets/scripts/navbar.js"></script>
    <script>
      import AOS from "aos";

      // Initialize AOS
      AOS.init();
    </script>
  </body>
</html>
