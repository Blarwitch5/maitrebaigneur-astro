---
import { Icon } from 'astro-icon/components';
import { reservationLink } from '@assets/data/data.json';
---

<a
  id='booking-fab'
  class='booking-fab'
  href={reservationLink}
  target='_blank'
  rel='noopener noreferrer'
  title='Réserver un cours'
  aria-label='Réserver un cours'
>
  <Icon name='calendar' />
  <span class='visually-hidden'>Réserver un cours</span>
  <span class='booking-fab__label' aria-hidden='true'>Réserver</span>
</a>

<script>
  const bookingFabSetup = () => {
    const fab = document.getElementById('booking-fab');
    if (!fab) return;

    const update = () => {
      const scrolled = (document.body.scrollTop || document.documentElement.scrollTop) > 20;
      fab.classList.toggle('is-visible', scrolled);
    };

    window.addEventListener('scroll', update, { passive: true });
    update();
  };

  bookingFabSetup();
  document.addEventListener('astro:after-swap', bookingFabSetup);
</script>
