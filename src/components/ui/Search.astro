<form class="search" role="search">
  <label for="search-field" class="sr-only">Rechercher dans la FAQ :</label>
  <input
    type="search"
    id="search-field"
    name="search"
    placeholder="Rechercher une question..."
    autocomplete="off"
  />
  <button type="button" id="clear-button" aria-label="Effacer la recherche">
    <span class="sr-only">Effacer</span>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18 18 6M6 6l12 12"/>
    </svg>
  </button>
</form>

<div id="no-results-message" aria-live="polite" aria-atomic="true" style="display:none">
  Désolé, il n'y a pas de résultat pour cette recherche.
</div>

<style lang="scss">
  .search {
    --color-gray: #e2ebf6;
    --color-dark-gray: #c4d1e1;
    --radio-border-width: 2px;

    position: relative;
    width: 100%;
    max-width: 800px;
    margin: auto;

    & > input {
      width: 100%;
      margin-block: var(--space-md);
      background-color: var(--color-white);
      border-radius: var(--regular-border-radius);
      padding: var(--space-xs) 4rem;
      border: var(--radio-border-width) solid var(--color-gray);
      font-size: var(--fs-base);

      &::placeholder {
        color: var(--color-dark-gray);
      }

      &:hover {
        border-color: var(--color-dark-gray);
      }
      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        box-shadow: 1px 1px 8px 1px hsla(var(--link-color-primary-hsl), 0.5);
      }
    }
    & > input[type="search"] {
      &::-webkit-search-cancel-button {
        display: none;
      }
    }

    & > button {
      visibility: hidden;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      right: calc(var(--space-xs) / 2);
      padding: var(--space-2xs);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      background-color: transparent;
      border: none;
      color: var(--color-secondary);
      transition: visibility 0.2s ease-in, color 0.2s ease;

      &:hover {
        color: var(--color-primary);
      }

      svg {
        width: 1.25rem;
        height: 1.25rem;
      }
    }
    &::before {
      width: 3rem;
      height: 3rem;
      content: "";
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      left: calc(var(--space-xs) / 2);
      display: flex;
      align-items: center;
      justify-content: center;
      background-image: url(../../assets/images/icons/search.svg);
      background-repeat: no-repeat;
      background-position: center;
      background-size: 60%;
      z-index: 9;
      pointer-events: none;
      opacity: 0.2;
    }
  }
</style>
<script>
  const searchSetup = () => {
    const searchInput = document.querySelector<HTMLInputElement>("#search-field");
    if (!searchInput) return;
    const clearButton = document.querySelector<HTMLButtonElement>("#clear-button")!;
    const accordionItems = document.querySelectorAll<HTMLLIElement>(".accordion__item")!;
    const noResultsMessage = document.querySelector<HTMLDivElement>("#no-results-message")!;

    const showAll = () => {
      accordionItems.forEach((item) => (item.style.display = "list-item"));
      noResultsMessage.style.display = "none";
      clearButton.style.visibility = "hidden";
    };

    searchInput.addEventListener("input", () => {
      const query = searchInput.value.trim().toLowerCase();
      if (query === "") {
        showAll();
        return;
      }
      let foundMatch = false;
      accordionItems.forEach((item) => {
        const title = item.querySelector(".accordion__title")?.textContent?.trim().toLowerCase();
        const panel = item.querySelector(".accordion__panel")?.textContent?.trim().toLowerCase();
        const matches = (title && title.includes(query)) || (panel && panel.includes(query));
        item.style.display = matches ? "list-item" : "none";
        if (matches) foundMatch = true;
      });
      clearButton.style.visibility = "visible";
      noResultsMessage.style.display = foundMatch ? "none" : "block";
    });

    clearButton.addEventListener("click", () => {
      searchInput.value = "";
      showAll();
      searchInput.focus();
    });
  };
  searchSetup();
  document.addEventListener("astro:after-swap", searchSetup);
</script>
