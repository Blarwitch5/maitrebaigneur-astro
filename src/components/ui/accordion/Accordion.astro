<div class="accordion">
	<ul class="accordion__wrapper" role="list">
		<slot />
	</ul>
</div>

<script type="module">
	const getPanelHeight = (item) =>
		item.querySelector(".panel-inner").getBoundingClientRect().height;

	const openAccordionItem = (item) => {
		const header = item.querySelector(".accordion__header");
		const panel = item.querySelector(".accordion__panel");
		panel.style.height = `${getPanelHeight(item)}px`;
		item.classList.add("is-active");
		header.setAttribute("aria-expanded", "true");
		panel.setAttribute("aria-hidden", "false");
	};

	const closeAccordionItem = (item) => {
		const header = item.querySelector(".accordion__header");
		const panel = item.querySelector(".accordion__panel");
		item.classList.remove("is-active");
		panel.style.height = 0;
		header.focus();
		header.setAttribute("aria-expanded", "false");
		panel.setAttribute("aria-hidden", "true");
	};

	const isAccordionOpen = (item) => item.classList.contains("is-active");

	window.toggleAccordionItem = () => {
		const item = event.target.closest(".accordion__item");
		if (!item || event.target.closest(".accordion__panel")) return;
		isAccordionOpen(item) ? closeAccordionItem(item) : openAccordionItem(item);
	};

	document.addEventListener("keydown", (event) => {
		const item = event.target.closest(".accordion__item");
		if (event.key !== "Escape" || !item) return;
		if (isAccordionOpen(item)) closeAccordionItem(item);
	});

	document.addEventListener("keydown", (event) => {
		if (!event.target.closest(".accordion__header")) return;
		const wrapper = event.target.closest(".accordion__wrapper");
		const item = event.target.closest(".accordion__item");
		if (!wrapper || !item) return;
		const items = [...wrapper.querySelectorAll(":scope > .accordion__item")];
		const index = items.indexOf(item);
		let target;
		if (event.key === "ArrowDown") target = items[index + 1];
		if (event.key === "ArrowUp") target = items[index - 1];
		if (target) {
			event.preventDefault();
			target.querySelector(".accordion__header").focus();
		}
	});

	window.onresize = () => {
		document.querySelectorAll(".accordion__item.is-active").forEach((item) => {
			item.querySelector(".accordion__panel").style.height = `${getPanelHeight(item)}px`;
		});
	};
</script>

<style lang="scss">
	.accordion {
		&__wrapper {
			list-style: none;
			padding-inline: 0;
			padding-block: 1rem;
		}
	}
</style>
