---
import Copyright from '@components/footer/Copyright.astro';
import Socials from '@components/Socials.astro';
import Button from '@components/ui/Button.astro';
import PoolList from '@components/widgets/PoolList.astro';
import { Icon } from 'astro-icon/components';
import Waves from '@components/ui/shapes/Waves.astro';
import GoToTop from '@components/ui/GoToTop.astro';
import StickyBtns from '@components/ui/StickyBtns.astro';

import site from '@assets/data/data.json';
import Title from './ui/Title.astro';
import { Image } from 'astro:assets';
import logo from '@assets/images/logo.svg';

import services from '@assets/data/services.ts';
const { siteLinks, googleRating, googleReviewCount } = site;
const footerMenu = siteLinks.footerMenu;

const GOOGLE_REVIEW_URL = 'https://www.google.com/search?q=maitre+baigneur#lrd=0x12c98f133b663547:0xd4550e7a8de92771,3,,,,';
const FACEBOOK_REVIEW_URL = 'https://www.facebook.com/MaitreBaigneur/reviews';
---

<footer class='footer'>
  <Waves atTopOfSection />
  <div class='container'>
    <div class='footer__sections'>
      <div class='footer__col brand'>
        <Image class='logo' width={300} height={250} src={logo} alt='Logo Maître-Baigneur' />

        <p class='slogan'>"...Nager, c'est toute l'année..."</p>
        <ul class='info'>
          <li>
            <Button class='btn' href='tel:+33677007584'>
              <span class='icon'>
                <Icon name='call' />
              </span>
              <span class='visually-hidden'>Appelez Maître Baigneur au +33 6 77 00 75 84</span>
              +33 6 77 00 75 84
            </Button>
          </li>
          <li>
            <Button class='btn' href='mailto:contact@maitrebaigneur.com'>
              <span class='icon'><Icon name='mail' /></span><span class='visually-hidden'
                >Écrivez-nous à contact@maitrebaigneur.com</span
              >contact@maitrebaigneur.com
            </Button>
          </li>
          <li>
            <span class='icon'><Icon name='location' /></span>Aix-en-Provence et ses alentours
          </li>
        </ul>
        <Socials iconVersion='light' />
      </div>

      <div class='footer__col services' data-aos='zoom-in'>
        <Title level='3' class='title'>Nos prestations</Title>
        <ul>
          {
            services.map((service) => (
              <li>
                <Button class='btn' href={service.href}>
                  {service.name}
                </Button>
              </li>
            ))
          }
        </ul>
      </div>
      <div class='footer__col useful-links' data-aos='zoom-in'>
        <Title level='3' class='title'>Besoin d'aide ?</Title>

        <ul>
          {
            footerMenu.map((item) => (
              <li>
                <Button class={item.classes} href={item.href} newTab={item.inNewTab}>
                  {item.name}
                </Button>
              </li>
            ))
          }
        </ul>
      </div>

      <div class='footer__col reviews' data-aos='zoom-in'>
        <Title level='3' class='title'>Donnez votre avis</Title>
        <ul>
          <li>
            <a href={GOOGLE_REVIEW_URL} target='_blank' rel='noopener noreferrer' class='review-link'>
              <span class='review-icon'><Icon name='google' /></span>
              <span class='review-body'>
                <span class='review-platform'>Google</span>
                <span class='review-rating'>
                  <Icon name='star' />
                  <strong>{googleRating}</strong>
                  <span class='review-count'>({googleReviewCount} avis)</span>
                </span>
              </span>
            </a>
          </li>
          <li>
            <a href={FACEBOOK_REVIEW_URL} target='_blank' rel='noopener noreferrer' class='review-link'>
              <span class='review-icon'><Icon name='facebook-review' /></span>
              <span class='review-body'>
                <span class='review-platform'>Facebook</span>
                <span class='review-subtitle'>Laissez votre avis</span>
              </span>
            </a>
          </li>
        </ul>
      </div>
      <div class='footer__col pools' data-aos='zoom-in'>
        <Title level='3' class='title'>Nos bassins</Title>
        <PoolList />
      </div>
    </div>
    <Copyright />
  </div>
  <StickyBtns />
  <!-- <GoToTop /> -->
</footer>

<style lang='scss'>
  .footer {
    background-color: var(--color-primary);
    color: var(--color-white);
    position: relative;

    &* {
      color: inherit;
    }
    .title {
      font-size: var(--fs-md);
      margin-bottom: var(--space-md);
      @media screen and (max-width: 576px) {
        margin-bottom: 1rem;
      }
    }

    &__sections {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: var(--space-md);
    }
    &__col {
      &.brand {
        grid-column: 1 / span 6;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        margin-bottom: 2rem;
        margin-top: -100px;
        text-align: center;
        z-index: 2;
      }
      &.pools {
        text-align: center;
        grid-column: 1 / span 6;
      }
      &.services {
        grid-column: 1 / span 2;
      }
      &.useful-links {
        grid-column: 3 / span 2;
      }
      &.reviews {
        grid-column: 5 / span 2;
      }
      &.services,
      &.useful-links,
      &.reviews {
        display: flex;
        justify-content: flex-start;
        flex-direction: column;

        .title {
          text-align: center;
        }
        ul {
          text-align: left;
          padding: 0;
          display: flex;
          flex-direction: column;
          gap: var(--space-2xs);

          a {
            padding: 0;
            min-height: unset;

            &:hover {
              text-decoration: underline;
              text-underline-offset: 3px;
            }
          }
        }
        @media screen and (max-width: 576px) {
          text-align: center;
          grid-column: 1 / span 6;
        }
      }

      &.reviews ul {
        list-style: none;

        li {
          padding: 0.5rem 0.75rem !important;
          margin-inline: -0.75rem;
          border-radius: 0.5rem;
          transition: background-color 0.15s ease;

          &:hover {
            background-color: var(--color-white-a25);
          }
        }
      }
    }

    .review-link {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      color: var(--color-white);
      text-decoration: none !important;

      &:hover {
        text-decoration: none !important;
      }
    }

    .review-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      width: 2rem;
      height: 2rem;

      svg {
        width: 2rem;
        height: 2rem;
      }
    }

    .review-body {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }

    .review-platform {
      font-weight: 700;
      font-size: var(--fs-base);
    }

    .review-rating {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 0.875rem;

      svg {
        width: 1rem;
        height: 1rem;
        color: #facc15;
      }
    }

    .review-count {
      opacity: 0.75;
    }

    .review-subtitle {
      font-size: 0.875rem;
      opacity: 0.75;
    }

    .logo {
      max-height: 250px;
      background-color: transparent;
      margin-inline: auto;
    }
    .slogan {
      margin-block: -2rem 0;
      font-family: var(--ff-pacifico);
      font-size: var(--fs-lg);
    }
    .info {
      padding: 0;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-md);

      @media screen and (max-width: 992px) {
        flex-direction: column;
        gap: var(--space-xs);
      }
      & > * {
        margin: 0;
      }

      & > li {
        display: flex;
        flex-wrap: nowrap;
        align-items: center;
        gap: var(--space-xs);

        .btn {
          display: flex;
          flex-wrap: nowrap;
          align-items: center;
          justify-content: center;
          gap: var(--space-xs);
        }
        .icon {
          display: flex;
          align-items: center;
          justify-content: center;
          width: 2.25rem;
          height: 2.25rem;
          flex-shrink: 0;

          svg {
            width: 2.25rem;
            height: 2.25rem;
          }
        }
      }
    }
  }
</style>
