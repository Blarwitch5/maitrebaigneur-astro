---
import Button from '@components/ui/Button.astro';
import site from '@assets/data/prices.json';
import Title from '@components/ui/Title.astro';
import { Icon } from 'astro-icon/components';

const { prices } = site;
const swimmingPrices = prices.swimmingLessons;
const diploma = prices.diploma;
const swimmingPricesHome = swimmingPrices.home;
const swimmingPricesPool = swimmingPrices.pool;

type HomeFormulaItem = { name: string; price: number; extraDesc?: string };
type HomeFormula = {
  '30min'?: HomeFormulaItem[];
  '1h'?: HomeFormulaItem[];
};

const homeFormula = swimmingPricesHome.formula as HomeFormula;
const homeFormula30 = homeFormula['30min'] ?? [];
const homeFormula1h = homeFormula['1h'] ?? [];
const hasHomeComparison = homeFormula1h.length > 0;
const homeRows = homeFormula30.map((item30, index) => {
  const item1h = homeFormula1h[index];
  return {
    name: item30.name,
    price30: item30.price,
    extra30: item30.extraDesc,
    price1h: item1h?.price,
    extra1h: item1h?.extraDesc,
  };
});

import { reservationLink } from '@assets/data/data.json';
---

<div class='location-toggle' role='group' aria-label='Lieu des séances'>
  <div class='location-toggle__slider' aria-hidden='true'></div>
  <button class='location-toggle__btn location-toggle__btn--active' id='btn-pool-swimming'>
    En bassin
  </button>
  <button class='location-toggle__btn' id='btn-home-swimming'>À domicile</button>
</div>

<div class='packages-container swimming'>
  <div id='price-package-home'>
    <div class='package package--wide'>
      <Title level='4' class='package__title'>Séance à l'unité</Title>
      {
        hasHomeComparison ? (
          <div class='package__table-wrapper'>
            <table class='package__table'>
              <thead>
                <tr>
                  <th />
                  <th>30min</th>
                  <th>1h</th>
                </tr>
              </thead>
              <tbody>
                {homeRows.map((row) => (
                  <tr>
                    <td>{row.name}</td>
                    <td>
                      <span class='package__price'>{row.price30}€</span>
                      {row.extra30 && <span class='package__extra-desc'>{row.extra30}</span>}
                    </td>
                    <td>
                      {typeof row.price1h === 'number' ? (
                        <>
                          <span class='package__price'>{row.price1h}€</span>
                          {row.extra1h && <span class='package__extra-desc'>{row.extra1h}</span>}
                        </>
                      ) : (
                        <span>-</span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <ul class='package__list'>
            {homeRows.map((row) => (
              <li class='package__item'>
                {row.name} <span class='package__price'>{row.price30}€</span>
                {row.extra30 && <span class='package__extra-desc'>{row.extra30}</span>}
              </li>
            ))}
          </ul>
        )
      }
      <Button href={reservationLink} class='btn btn__regular'> Réserver </Button>
    </div>
  </div>
  <div id='price-package-pool'>
    <div class='package'>
      <Title level='4' class='package__title'>Séance à l'unité</Title>
      <ul class='package__list'>
        {
          swimmingPricesPool.single.map(
            (item: { name: string; price: number; extraDesc?: string }) => (
              <li class='package__item'>
                {item.name} <span class='package__price'>{item.price}€</span>
                {item.extraDesc && <span class='package__extra-desc'>{item.extraDesc}</span>}
              </li>
            )
          )
        }
      </ul>
      <Button href={reservationLink} class='btn btn__regular' newTab> Réserver </Button>
    </div>

    <div class='package'>
      <Title level='4' class='package__title'>Nos formules</Title>
      <Title level='5' class='package__subtitle'>Seul ou à partager</Title>
      <ul class='package__list'>
        {
          swimmingPricesPool.formula.map(
            (item: {
              name: string;
              price: number;
              totalPrice?: number;
              validity?: string;
              installments?: string;
              badge?: string;
            }) => (
              <li class='package__item package__item--formula'>
                <span class='package__item-name'>
                  {item.name}
                  {item.badge && <span class='package__badge'>{item.badge}</span>}
                </span>
                <span class='package__total'>
                  {item.totalPrice ? (
                    <>
                      <span class='package__price'>{item.totalPrice}€</span>
                      <span class='package__per-session'>{item.price}€/séance</span>
                    </>
                  ) : (
                    <span class='package__price'>{item.price}€</span>
                  )}
                </span>
                {item.validity && (
                  <span class='package__validity'>{item.validity}</span>
                )}
                {item.installments && (
                  <span class='package__installments'>{item.installments}</span>
                )}
              </li>
            )
          )
        }
      </ul>
      <Button href={reservationLink} class='btn btn__regular' newTab> Réserver </Button>
    </div>
  </div>
</div>

<div class='diploma-note'>
  <Icon name='diploma' aria-hidden='true' />
  <div>
    <p class='diploma-note__title'>Diplôme 50m & Test d'aisance aquatique — {diploma.price}€</p>
    <p class='diploma-note__desc'>
      Le <strong>diplôme 50m</strong> valide la capacité à nager sans s'arrêter avec une technique
      correcte. Le <strong>test d'aisance aquatique</strong> évalue l'autonomie en cas de chute
      accidentelle dans l'eau.
    </p>
  </div>
</div>

<style lang='scss'>
  .location-toggle {
    position: relative;
    display: flex;
    background-color: var(--color-bg-light);
    border-radius: var(--regular-border-radius);
    padding: 4px;
    gap: 4px;
    width: fit-content;
    margin-inline: auto;
    margin-block: 2rem;

    &__slider {
      position: absolute;
      top: 4px;
      left: 4px;
      height: calc(100% - 8px);
      width: calc(50% - 6px);
      background-color: var(--color-primary);
      border-radius: calc(var(--regular-border-radius) - 2px);
      box-shadow:
        0 2px 8px hsla(var(--link-color-primary-hsl), 0.25),
        0 1px 2px hsla(var(--link-color-primary-hsl), 0.15);
      transition: transform 0.25s ease;
      pointer-events: none;
      will-change: transform;
    }

    &__btn {
      position: relative;
      z-index: 1;
      padding: var(--space-2xs) var(--space-sm);
      border: none;
      border-radius: calc(var(--regular-border-radius) - 2px);
      background-color: transparent;
      cursor: pointer;
      font-size: var(--fs-sm);
      font-weight: 500;
      color: var(--color-black);
      transition: color 0.25s ease;

      &--active {
        color: var(--color-white);
      }

      &:hover:not(&--active) {
        color: var(--color-primary);
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        border-radius: calc(var(--regular-border-radius) - 2px);
      }
    }
  }

  .packages-container {
    #price-package-home {
      display: none;
    }
  }

  .package {
    &--wide {
      flex-basis: min(680px, 100%);
    }

    &__table-wrapper {
      width: 100%;
      overflow-x: auto;
    }

    &__table {
      width: 100%;
      border-collapse: collapse;
      text-align: center;
      table-layout: fixed;

      th,
      td {
        width: 33.333%;
        padding: var(--space-2xs);
        vertical-align: top;
        text-align: center;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      th {
        font-weight: 700;
        font-size: var(--fs-sm);
      }

      tbody tr:not(:last-child) {
        border-bottom: 1px solid hsla(var(--link-color-primary-hsl), 0.1);
      }

      th,
      td {
        white-space: nowrap;
      }
    }

    &__table td .package__price {
      display: inline-flex;
      margin-bottom: 0.25rem;
    }

    &__table td .package__extra-desc {
      display: block;
      text-align: center;
      font-size: calc(var(--fs-base) * 0.82);
      font-style: italic;
      color: var(--color-secondary);
      margin-top: 0.25rem;
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    &__item--formula {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto auto;
      align-items: start;
    }

    &__item-name {
      display: flex;
      align-items: center;
      gap: var(--space-2xs);
      flex-wrap: wrap;
    }

    &__badge {
      display: inline-block;
      background-color: var(--color-secondary);
      color: var(--color-white);
      padding: 1px var(--space-2xs);
      border-radius: 100vh;
      font-size: calc(var(--fs-base) * 0.75);
      font-weight: 600;
      white-space: nowrap;
    }

    &__total {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2px;
    }

    &__per-session {
      font-size: calc(var(--fs-base) * 0.8);
      color: var(--color-secondary);
      font-style: italic;
      white-space: nowrap;
    }

    &__validity {
      grid-column: 1 / -1;
      font-size: calc(var(--fs-base) * 0.8);
      color: hsla(var(--link-color-black-hsl), 0.5);
      padding-top: 2px;
    }

    &__installments {
      grid-column: 1 / -1;
      display: inline-flex;
      width: fit-content;
      background-color: hsla(var(--link-color-primary-hsl), 0.08);
      color: var(--color-primary);
      padding: 2px var(--space-xs);
      border-radius: 100vh;
      font-size: calc(var(--fs-base) * 0.8);
      font-weight: 600;
      margin-top: var(--space-2xs);
    }
  }

  .diploma-note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: linear-gradient(to right, var(--color-secondary) 3px, var(--color-bg-light) 3px);
    border-radius: var(--regular-border-radius);

    svg {
      width: 2rem;
      height: 2rem;
      color: var(--color-secondary);
      flex-shrink: 0;
      margin-top: 2px;
    }

    &__title {
      font-family: var(--ff-pacifico);
      font-size: var(--fs-xs);
      color: var(--color-primary);
      margin: 0 0 var(--space-2xs);
    }

    &__desc {
      font-size: var(--fs-base);
      color: var(--color-black-a75);
      margin: 0;
      line-height: 1.6;
    }
  }
</style>
<script>
  function swimmingPricesSetup() {
    const btnPool = document.getElementById('btn-pool-swimming') as HTMLButtonElement;
    const btnHome = document.getElementById('btn-home-swimming') as HTMLButtonElement;
    const pricePackageHome = document.getElementById('price-package-home');
    const pricePackagePool = document.getElementById('price-package-pool');
    const slider = btnPool?.closest('.location-toggle')?.querySelector<HTMLElement>('.location-toggle__slider');

    if (!btnPool || !btnHome || !pricePackageHome || !pricePackagePool) return;

    function setLocation(location: 'pool' | 'home') {
      const isHome = location === 'home';
      pricePackageHome!.style.display = isHome ? 'flex' : 'none';
      pricePackagePool!.style.display = isHome ? 'none' : 'flex';
      btnPool.classList.toggle('location-toggle__btn--active', !isHome);
      btnHome.classList.toggle('location-toggle__btn--active', isHome);
      if (slider) slider.style.transform = isHome ? 'translateX(calc(100% + 4px))' : 'translateX(0)';
    }

    btnPool.addEventListener('click', () => setLocation('pool'));
    btnHome.addEventListener('click', () => setLocation('home'));
  }
  swimmingPricesSetup();
  document.addEventListener('astro:after-swap', swimmingPricesSetup);
</script>
