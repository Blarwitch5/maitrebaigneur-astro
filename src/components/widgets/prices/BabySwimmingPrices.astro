---
import Button from '@components/ui/Button.astro';
import site from '@assets/data/prices.json';
import { Icon } from 'astro-icon/components';
import Title from '@components/ui/Title.astro';

import { reservationLink } from '@assets/data/data.json';

const { prices } = site;
const babySwimming = prices.babySwimming;
const babySwimmingHome = babySwimming.home;
const babySwimmingPool = babySwimming.pool;
---

<div class='location-toggle' role='group' aria-label='Lieu des séances'>
  <div class='location-toggle__slider' aria-hidden='true'></div>
  <button class='location-toggle__btn location-toggle__btn--active' id='btn-pool-baby'>
    En bassin
  </button>
  <button class='location-toggle__btn' id='btn-home-baby'>À domicile</button>
</div>

<div class='packages-container baby-swimming'>
  <div id='price-package-home-baby'>
    <div class='package'>
      <Title level='4' class='package__title'>Séance à l'unité</Title>
      <p class='package__info'>
        <Icon name='warning' /> Attention l'eau de la piscine doit être à 30°C minimum
      </p>
      <ul class='package__list'>
        {
          babySwimmingHome.formula.map(
            (item: { name: string; price: number; extraDesc?: string }) => (
              <li class='package__item'>
                {item.name} <span class='package__price'>{item.price}€</span>
                {item.extraDesc && <span class='package__extra-desc'>{item.extraDesc}</span>}
              </li>
            )
          )
        }
      </ul>
      <Button href={reservationLink} class='btn btn__regular'> Réserver </Button>
    </div>
  </div>
  <div id='price-package-pool-baby'>
    <div class='package'>
      <Title level='4' class='package__title'>Séance à l'unité</Title>
      <ul class='package__list'>
        {
          babySwimmingPool.single.map(
            (item: { name: string; price: number; extraDesc?: string }) => (
              <li class='package__item'>
                {item.name} <span class='package__price'>{item.price}€</span>
                {item.extraDesc && <span class='package__extra-desc'>{item.extraDesc}</span>}
              </li>
            )
          )
        }
      </ul>
      <Button href={reservationLink} class='btn btn__regular' newTab> Réserver </Button>
    </div>

    <div class='package'>
      <Title level='4' class='package__title'>Nos formules</Title>
      <Title level='5' class='package__subtitle'>Seul ou à partager</Title>
      <ul class='package__list'>
        {
          babySwimmingPool.formula.map(
            (item: {
              name: string;
              price: number;
              totalPrice?: number;
              validity?: string;
              installments?: string;
              badge?: string;
            }) => (
              <li class='package__item package__item--formula'>
                <span class='package__item-name'>
                  {item.name}
                  {item.badge && <span class='package__badge'>{item.badge}</span>}
                </span>
                <span class='package__total'>
                  {item.totalPrice ? (
                    <>
                      <span class='package__price'>{item.totalPrice}€</span>
                      <span class='package__per-session'>{item.price}€/séance</span>
                    </>
                  ) : (
                    <span class='package__price'>{item.price}€</span>
                  )}
                </span>
                {item.validity && <span class='package__validity'>{item.validity}</span>}
                {item.installments && (
                  <span class='package__installments'>{item.installments}</span>
                )}
              </li>
            )
          )
        }
      </ul>
      <Button href={reservationLink} class='btn btn__regular' newTab> Réserver </Button>
    </div>
  </div>
</div>

<style lang='scss'>
  .location-toggle {
    position: relative;
    display: flex;
    background-color: var(--color-bg-light);
    border-radius: var(--regular-border-radius);
    padding: 4px;
    gap: 4px;
    width: fit-content;
    margin-inline: auto;
    margin-block: 2rem;

    &__slider {
      position: absolute;
      top: 4px;
      left: 4px;
      height: calc(100% - 8px);
      width: calc(50% - 6px);
      background-color: var(--color-primary);
      border-radius: calc(var(--regular-border-radius) - 2px);
      box-shadow:
        0 2px 8px hsla(var(--link-color-primary-hsl), 0.25),
        0 1px 2px hsla(var(--link-color-primary-hsl), 0.15);
      transition: transform 0.25s ease;
      pointer-events: none;
      will-change: transform;
    }

    &__btn {
      position: relative;
      z-index: 1;
      padding: var(--space-2xs) var(--space-sm);
      border: none;
      border-radius: calc(var(--regular-border-radius) - 2px);
      background-color: transparent;
      cursor: pointer;
      font-size: var(--fs-sm);
      font-weight: 500;
      color: var(--color-black);
      transition: color 0.25s ease;

      &--active {
        color: var(--color-white);
      }

      &:hover:not(&--active) {
        color: var(--color-primary);
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        border-radius: calc(var(--regular-border-radius) - 2px);
      }
    }
  }

  .packages-container {
    #price-package-home-baby {
      display: none;
    }
  }

  .package {
    &__item--formula {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto auto;
      align-items: start;
    }

    &__item-name {
      display: flex;
      align-items: center;
      gap: var(--space-2xs);
      flex-wrap: wrap;
    }

    &__badge {
      display: inline-block;
      background-color: var(--color-secondary);
      color: var(--color-white);
      padding: 1px var(--space-2xs);
      border-radius: 100vh;
      font-size: calc(var(--fs-base) * 0.75);
      font-weight: 600;
      white-space: nowrap;
    }

    &__total {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2px;
    }

    &__per-session {
      font-size: calc(var(--fs-base) * 0.8);
      color: var(--color-secondary);
      font-style: italic;
      white-space: nowrap;
    }

    &__validity {
      grid-column: 1 / -1;
      font-size: calc(var(--fs-base) * 0.8);
      color: hsla(var(--link-color-black-hsl), 0.5);
      padding-top: 2px;
    }

    &__installments {
      grid-column: 1 / -1;
      display: inline-flex;
      width: fit-content;
      background-color: hsla(var(--link-color-primary-hsl), 0.08);
      color: var(--color-primary);
      padding: 2px var(--space-xs);
      border-radius: 100vh;
      font-size: calc(var(--fs-base) * 0.8);
      font-weight: 600;
      margin-top: var(--space-2xs);
    }
  }
</style>
<script>
  function babySwimmingSetup() {
    const btnPool = document.getElementById('btn-pool-baby') as HTMLButtonElement;
    const btnHome = document.getElementById('btn-home-baby') as HTMLButtonElement;
    const pricePackageHomeBaby = document.getElementById('price-package-home-baby');
    const pricePackagePoolBaby = document.getElementById('price-package-pool-baby');
    const slider = btnPool?.closest('.location-toggle')?.querySelector<HTMLElement>('.location-toggle__slider');

    if (!btnPool || !btnHome || !pricePackageHomeBaby || !pricePackagePoolBaby) return;

    function setLocation(location: 'pool' | 'home') {
      const isHome = location === 'home';
      pricePackageHomeBaby!.style.display = isHome ? 'flex' : 'none';
      pricePackagePoolBaby!.style.display = isHome ? 'none' : 'flex';
      btnPool.classList.toggle('location-toggle__btn--active', !isHome);
      btnHome.classList.toggle('location-toggle__btn--active', isHome);
      if (slider) slider.style.transform = isHome ? 'translateX(calc(100% + 4px))' : 'translateX(0)';
    }

    btnPool.addEventListener('click', () => setLocation('pool'));
    btnHome.addEventListener('click', () => setLocation('home'));
  }
  babySwimmingSetup();
  document.addEventListener('astro:after-swap', babySwimmingSetup);
</script>
