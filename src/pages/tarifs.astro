---
import BaseLayout from '@layouts/BaseLayout.astro';
import Main from '@components/Main.astro';

import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import PageTitle from '@components/header/PageTitle.astro';
import SkipToContent from '@components/ui/SkipToContent.astro';
import { Icon } from 'astro-icon/components';

import SwimmingPrices from '@components/widgets/prices/SwimmingPrices.astro';
import BabySwimmingPrices from '@components/widgets/prices/BabySwimmingPrices.astro';
import Title from '@components/ui/Title.astro';
import Button from '@components/ui/Button.astro';

import tarifs from '@assets/images/page-title/page_tarifs.jpg';
import pricesData from '@assets/data/prices.json';

const { prices } = pricesData;

const page = {
  metaTitle: 'Tarifs et formules : natation, bébé nageur, événements',
  description:
    "Consultez les tarifs des cours de natation, bébé nageur, aquaversaire et surveillance d'événements de Maître Baigneur à Aix-en-Provence. Formules adaptées à tous les niveaux.",
  title: 'Nos tarifs',
  image: {
    path: tarifs,
    alt: "Enfant sur bouée gonflable avec des lunettes de soleil faisant le signe Rock N' Roll de la main",
  },
};
---

<BaseLayout title={page.metaTitle} description={page.description}>
  <SkipToContent />
  <Header />
  <PageTitle pageTitle={page.title} pageImagePath={page.image.path} pageImageAlt={page.image.alt} />

  <Main>
    <section>
      <div class='container'>
        <div class='pricing'>
          <div>
            <Title level='2' animate>Choisissez votre formule</Title>
            <p>
              Que vous soyez à la recherche de leçons de natation en bassin ou à domicile, de cours
              bébé nageur, ou d'une animation aquatique pour un événement, nous avons ce qu'il vous
              faut.
            </p>
          </div>

          <!-- Onglets principaux : les deux prestations récurrentes -->
          <div class='pricing__nav tab'>
            <div class='tab__title'></div>
            <div class='tab__buttons' role='tablist'>
              <button
                id='tab-natation'
                class='tab__button active'
                role='tab'
                aria-selected='true'
                aria-controls='swimming-station__section'
                data-option='lecons-de-natation'
                tabindex='0'
              >
                <Icon name='fun' />
                <span>Cours de natation</span>
                <span class='tab__price'>dès {prices.swimmingLessons.pool.single[0].price}€</span>
              </button>
              <button
                id='tab-bebe'
                class='tab__button'
                role='tab'
                aria-selected='false'
                aria-controls='baby-swimming__section'
                data-option='bebe-nageur'
                tabindex='-1'
              >
                <Icon name='baby' />
                <span>Bébé nageur</span>
                <span class='tab__price'>dès {prices.babySwimming.pool.single[0].price}€</span>
              </button>
            </div>
          </div>

          <div class='pricing__content tab__panels'>
            <div
              id='swimming-station__section'
              class='pricing__section tab__panel active'
              role='tabpanel'
              aria-labelledby='tab-natation'
            >
              <Title level='3'>Tarifs des cours de natation</Title>
              <p class='desc'>
                Cours pour tous les niveaux, du débutant au nageur avancé, en bassin
                d'apprentissage ou à domicile. Individuels ou en petit groupe, avec un moniteur
                professionnel. Séances de <strong>45 minutes</strong>, à partir de <span
                  class='highlight-price'>20€</span
                >.
              </p>
              <div class='pricing__wrapper'>
                <SwimmingPrices />
              </div>
            </div>

            <div
              id='baby-swimming__section'
              class='pricing__section tab__panel'
              role='tabpanel'
              aria-labelledby='tab-bebe'
              aria-hidden='true'
            >
              <Title level='3'>Tarifs des cours bébé nageur</Title>
              <p class='desc'>
                Cours dédiés aux enfants de 3 mois à 3 ans pour les initier à l'eau en douceur.
                Séances de <strong>30 minutes</strong>, à partir de <span class='highlight-price'
                  >20€</span
                >.
              </p>
              <ul>
                <li>Les cours sont exclusivement réservés aux bébés.</li>
                <li>
                  Pour ceux qui ne sont <strong>pas encore totalement propres</strong>, une <strong
                    >couche aquatique est obligatoire</strong
                  >, portée sous le maillot de bain.
                </li>
                <li>
                  Les parents peuvent accompagner leur enfant seul ou à deux, avec le maillot de
                  bain de leur choix.
                </li>
                <li>Le port du bonnet et des lunettes n'est pas obligatoire.</li>
              </ul>
              <div class='pricing__wrapper'>
                <BabySwimmingPrices />
              </div>
            </div>
          </div>

          <!-- Section événements : Surveillance + Aquaversaire -->
          <div class='pricing__events'>
            <Title level='3' class='pricing__events-title'>Événements aquatiques</Title>
            <p class='pricing__events-intro'>
              Sécurité et animation pour vos événements privés en piscine à Aix-en-Provence —
              maître-nageur qualifié, matériel de premiers secours inclus.
            </p>
            <div class='pricing__events-grid'>

              <div class='package'>
                <div class='event-header'>
                  <Icon name='event' aria-hidden='true' />
                  <Title level='4' class='package__title'>Surveillance d'événements</Title>
                </div>
                <p>
                  Maître-nageur qualifié pour sécuriser vos événements privés en piscine, de jour
                  comme de nuit. Matériel de premiers secours inclus.
                </p>
                <ul class='package__list'>
                  <li class='package__item'>
                    {prices.events.condition}
                    <span class='package__price'>{prices.events.price}€</span>
                  </li>
                </ul>
                <Button href='/contact?option=securiser-un-evenement' class='btn btn__regular'>
                  Demander un devis
                </Button>
              </div>

              <div class='package'>
                <div class='event-header'>
                  <Icon name='aquaversaire' aria-hidden='true' />
                  <Title level='4' class='package__title'>Aquaversaire</Title>
                </div>
                <p>{prices.aquaversaire.desc}</p>
                <ul class='package__list'>
                  <li class='package__item'>
                    {prices.aquaversaire.surveillanceTime} heures
                    <span class='package__price'>{prices.aquaversaire.price}€</span>
                  </li>
                  <li class='package__item'>
                    {prices.aquaversaire.extra.desc}
                    <span class='package__price'>{prices.aquaversaire.extra.price}€</span>
                  </li>
                </ul>
                <Button
                  href='/contact?option=organiser-un-aquaversaire'
                  class='btn btn__regular'
                  newTab
                >
                  Demander un devis
                </Button>
              </div>

            </div>
          </div>

        </div>
      </div>
    </section>
  </Main>
  <Footer />
</BaseLayout>

<style lang='scss'>
  .pricing {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);

    .tab {
      &__title {
        display: none;
        opacity: 0;
        padding: var(--space-md);
        justify-content: center;
        font-family: var(--ff-pacifico);
        font-size: var(--fs-sm);

        @media screen and (max-width: 576px) {
          opacity: 1;
          display: flex;
        }
      }
      &__panels {
        padding-block: var(--space-md);
      }
      &__panel {
        position: relative;
        width: 100%;
        max-height: 0;
        opacity: 0;
        visibility: hidden;
        transition:
          opacity 0.3s ease-in-out,
          max-height 0s linear 0.3s;

        p {
          margin-block: 0;
        }
        &.active {
          max-height: 100%;
          opacity: 1;
          visibility: visible;
          transition-delay: 0.3s;
        }
        &.previous {
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: auto;
          opacity: 0;
          visibility: hidden;
          transition:
            opacity 0.3s ease-in-out,
            height 0s linear;
        }
      }
      &__buttons {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-sm);
      }
      &__button {
        padding: var(--space-xs);
        border: none;
        border-radius: var(--regular-border-radius);
        background-color: var(--color-bg-light);
        cursor: pointer;
        color: var(--color-black);
        font-size: var(--fs-base);
        transition: all 0.2s ease-in-out;
        box-shadow:
          0 10px 15px -3px hsla(var(--link-color-primary-hsl), 0.3),
          0 4px 6px -4px hsla(var(--link-color-primary-hsl), 0.3);

        &:hover {
          color: var(--color-white);
          background-color: var(--color-secondary);
        }
        &.active {
          color: var(--color-white);
          box-shadow: none;
          background-color: var(--color-primary);
          cursor: default;
        }
        svg {
          width: 2.5rem;
          height: 2.5rem;
          max-width: var(--space-xl);
          margin-bottom: var(--space-2xs);
          display: block;
          margin-inline: auto;
          flex-shrink: 0;
        }
      }
    }

    &__content {
      .highlight-price {
        font-size: var(--fs-xs);
        font-weight: bold;
      }
    }

    &__wrapper {
      padding: var(--space-md);
      display: flex;
      justify-content: center;
      flex-direction: column;
      @media screen and (max-width: 768px) {
        padding-inline: 0;
      }
    }

    &__events {
      padding-top: var(--space-lg);
      border-top: 1px solid hsla(var(--link-color-primary-hsl), 0.1);
    }

    &__events-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
      margin-top: var(--space-md);

      @media screen and (max-width: 768px) {
        grid-template-columns: 1fr;
      }
    }
  }

  .tab__price {
    display: block;
    font-size: var(--fs-base);
    opacity: 0.75;
    margin-top: 2px;
  }

  .pricing__events-title {
    text-align: center;
  }

  .pricing__events-intro {
    text-align: center;
    color: var(--color-black-a75);
    margin-top: var(--space-2xs);
    margin-bottom: 0;
  }

  .pricing__events-grid .package {
    flex-basis: 100%;
    padding: var(--space-lg);
    text-align: left;
    align-items: flex-start;

    p {
      margin: 0;
      font-size: var(--fs-base);
      color: var(--color-black-a75);
      line-height: 1.6;
      text-align: left;
    }

    .btn {
      align-self: center;
      margin-top: auto;
    }
  }

  .event-header {
    display: flex;
    align-items: center;
    gap: var(--space-xs);

    svg {
      width: 2rem;
      height: 2rem;
      color: var(--color-primary);
      flex-shrink: 0;
    }

    .package__title {
      margin: 0;
    }
  }
</style>

<script>
  const pricesSetup = () => {
    const tabButtons = document.querySelectorAll<HTMLButtonElement>('.tab__button');
    const tabPanels = document.querySelectorAll<HTMLDivElement>('.tab__panel');

    if (!tabButtons.length || !tabPanels.length) return;

    function showPanel(panelIndex: number): void {
      const newPanel = tabPanels[panelIndex];
      if (!newPanel) return;

      const currentPanel = document.querySelector<HTMLDivElement>(
        '.pricing__section.previous, .pricing__section.active'
      );

      if (currentPanel) {
        currentPanel.classList.remove('active');
        currentPanel.classList.add('previous');
        currentPanel.setAttribute('aria-hidden', 'true');
      }
      newPanel.classList.add('active');
      newPanel.classList.remove('previous');
      newPanel.setAttribute('aria-hidden', 'false');

      tabButtons.forEach((button) => {
        button.classList.remove('active');
        button.setAttribute('aria-selected', 'false');
        button.setAttribute('tabindex', '-1');
      });

      tabPanels.forEach((panel) => {
        if (panel !== currentPanel && panel !== newPanel) {
          panel.classList.remove('active', 'previous');
          panel.setAttribute('aria-hidden', 'true');
        }
      });

      const selectedButton = tabButtons[panelIndex];
      if (selectedButton) {
        selectedButton.classList.add('active');
        selectedButton.setAttribute('aria-selected', 'true');
        selectedButton.setAttribute('tabindex', '0');

        const labelText = selectedButton.querySelector<HTMLSpanElement>('span:not(.tab__price)')?.innerHTML;
        if (labelText) {
          const tabTitle = document.querySelector<HTMLElement>('.tab__title');
          if (tabTitle) tabTitle.innerHTML = labelText;
        }

        const option = selectedButton.getAttribute('data-option') || '';
        const url = new URL(window.location.href);
        url.searchParams.set('option', option);
        window.history.replaceState({}, '', url.toString());
      }
    }

    const urlOption = new URLSearchParams(window.location.search).get('option');
    const initialIndex = urlOption
      ? Array.from(tabButtons).findIndex((btn) => btn.getAttribute('data-option') === urlOption)
      : -1;
    showPanel(initialIndex !== -1 ? initialIndex : 0);

    tabButtons.forEach((button, index) => {
      button.addEventListener('click', () => showPanel(index));
    });

    const tabList = document.querySelector('[role="tablist"]');
    tabList?.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      const currentIndex = Array.from(tabButtons).findIndex(
        (btn) => btn.getAttribute('aria-selected') === 'true'
      );
      let next = currentIndex;

      if (ke.key === 'ArrowRight') next = (currentIndex + 1) % tabButtons.length;
      else if (ke.key === 'ArrowLeft') next = (currentIndex - 1 + tabButtons.length) % tabButtons.length;
      else if (ke.key === 'Home') next = 0;
      else if (ke.key === 'End') next = tabButtons.length - 1;
      else return;

      ke.preventDefault();
      showPanel(next);
      tabButtons[next].focus();
    });
  };

  pricesSetup();
  document.addEventListener('astro:after-swap', pricesSetup);
</script>
