---
import BaseLayout from '@layouts/BaseLayout.astro';
import Main from '@components/Main.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import PageTitle from '@components/header/PageTitle.astro';
import SkipToContent from '@components/ui/SkipToContent.astro';

import site from '@assets/data/data.json';
import Services from '@components/widgets/Services.astro';
import Title from '@components/ui/Title.astro';

import fallback from '@assets/images/page-title/fallback.jpg';

const { siteLinks } = site;
const services = siteLinks.services;

//data

const page = {
  metaTitle: 'Nos prestations aquatiques',
  description: 'Découvrez les prestations aquatiques de Maître Baigneur à Aix-en-Provence : cours de natation, bébé nageur dès 3 mois, aquaversaire et surveillance d\'événements privés.',
  title: 'Nos prestations',

  image: {
    path: fallback,
    alt: "Vue sur des pieds trempants dans l'eau d'une piscine",
  },
};
---

<BaseLayout title={page.metaTitle} description={page.description}>
  <SkipToContent />
  <Header />
  <PageTitle pageTitle={page.title} pageImagePath={page.image.path} pageImageAlt={page.image.alt} />

  <Main>
    <section class='services' aria-label="Les bassins d'apprentissage de Maître-Baigneur">
      <div class='container'>
        <Title level='2' animate>Cours et services aquatiques à Aix-en-Provence</Title>
        <p>
          Maître Baigneur propose des cours de natation et de bébé nageur en petits groupes, encadrés
          par des maîtres-nageurs diplômés d'État. Les séances débutent dès 3 mois pour les bébés
          nageurs et dès 3 ans pour les cours de natation, sans limite d'âge vers le haut.
        </p>
        <p>
          Nous intervenons dans plusieurs bassins partenaires à Aix-en-Provence et ses environs,
          ainsi qu'à domicile. Pour vos événements privés, nous assurons également la surveillance
          de baignade et organisons des aquaversaires pour les anniversaires en piscine.
        </p>
        <Services />
      </div>
    </section>
    <Footer />
  </Main>
</BaseLayout>
<style></style>
