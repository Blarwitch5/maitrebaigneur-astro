---
import BaseLayout from '@layouts/BaseLayout.astro';
import Main from '@components/Main.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import PageTitle from '@components/header/PageTitle.astro';
import Pools from '@components/widgets/Pools.astro';
import SkipToContent from '@components/ui/SkipToContent.astro';

import fallback from '@assets/images/page-title/fallback.jpg';

//data

const page = {
  metaTitle: "Bassins d'apprentissage à Aix-en-Provence et alentours",
  description:
    "Découvrez les bassins d'apprentissage de Maître Baigneur à Aix-en-Provence et ses environs. Cours de natation et bébé nageur pour tous les âges avec nos maîtres-nageurs diplômés.",
  title: "Bassins d'apprentissage",

  image: {
    path: fallback,
    alt: "Vue sur des pieds trempants dans l'eau d'une piscine",
  },
};
---

<BaseLayout title={page.metaTitle} description={page.description}>
  <SkipToContent />
  <Header />
  <PageTitle pageTitle={page.title} pageImagePath={page.image.path} pageImageAlt={page.image.alt} />

  <Main>
    <section class='pools' aria-label="Les bassins d'apprentissage de Maître-Baigneur">
      <Pools />
    </section>
    <section class='pools-info'>
      <div class='container'>
        <p>
          Certains bassins sont ouverts uniquement en été, d'autres fonctionnent toute l'année.
          Maître Baigneur intervient également à domicile si vous disposez de votre propre piscine.
          Quel que soit le bassin, nos maîtres-nageurs diplômés d'État apportent leur matériel et
          assurent un encadrement en petits groupes pour tous les âges, dès 3 mois.
        </p>
        <p>
          Vous souhaitez accueillir Maître Baigneur dans votre établissement ?
          <a href='/contact?option=autres-questions-ou-suggestions'>Contactez-nous</a> pour discuter
          d'une collaboration.
        </p>
      </div>
    </section>
  </Main>
  <Footer />
</BaseLayout>
<style>
  .pools-info {
    padding-bottom: var(--space-xl);
  }
</style>
