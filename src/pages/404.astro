---
const page = {
  metaTitle: 'Page introuvable',
  description:
    "Cette page n'existe pas ou a été déplacée. Retrouvez nos cours de natation, bébé nageur et aquaversaire sur le site Maître Baigneur.",
  title: '404',
};
import Favicon from '@components/head/Favicon.astro';

import '../assets/styles/main.scss';
import Title from '@components/ui/Title.astro';

import services from '@assets/data/services.ts';
const swimming = services.find((service) => service.name.includes('natation')) ?? {
  name: 'cours de natation',
  href: '/prestations/cours-de-natation',
};
const babySwimming = services.find((service) => service.name.includes('bébé')) ?? {
  name: 'cours bébé nageur',
  href: '/prestations/cours-bebe-nageur',
};
---

<!doctype html>
<html lang='fr'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <meta name='generator' content={Astro.generator} />

    <title>{page.metaTitle} | Maître Baigneur</title>
    <meta name="description" content={page.description} />
    <meta name="robots" content="noindex" />

    <!-- FAVICON -->
    <Favicon />
    <!-- /FAVICON -->
  </head>
  <body>
    <main class='page-404'>
      <p>404</p>
      <Title level='1' animate>🌊 Oups !</Title>
      <p>On dirait que cette page a été emportée par les vagues !</p>
      <p>Ne t'inquiète pas, notre équipe de Maîtres-Baigneurs est déjà à sa recherche.</p>
      <p>
        En attendant, pourquoi ne pas retourner à la <a href='/'>page d'accueil</a> et découvrir nos
        fantastiques <a href={swimming.href}>{swimming.name}</a> et <a href={babySwimming.href}
          >{babySwimming.name}</a
        > ?
      </p>
      <p>À bientôt dans l'eau ! 🏊‍♂️</p>
    </main>
    <style lang='scss'>
      .page-404 {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        text-align: center;
        font-size: 1.5rem;
        line-height: 1.5;
        font-weight: 300;
        color: var(--color-primary);
        h1 {
          font-size: 3rem;
          font-weight: 700;
          margin-bottom: 1rem;
        }
        a {
          color: var(--color-primary);
          &:hover {
            color: var(--color-primary-dark);
          }
        }
      }
    </style>
  </body>
</html>
